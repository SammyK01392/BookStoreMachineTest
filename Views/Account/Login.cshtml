@model BookStoreMachineTest.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = null; /* Full-page layout — no navbar */
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — Book Store</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="login-page">
        <div class="login-card">
            <div class="login-logo">
                <div class="logo-icon">📚</div>
                <h1>Book Store</h1>
                <p>Sign in to manage your collection</p>
            </div>

            @if (!string.IsNullOrEmpty(ViewBag.Error))
            {
                <div class="login-error">@ViewBag.Error</div>
            }

            <form asp-controller="Account" asp-action="Login" method="post">
                <input type="hidden" name="ReturnUrl" value="@ViewBag.ReturnUrl" />

                <div class="form-group">
                    <label asp-for="Email">Email address</label>
                    <input asp-for="Email" class="form-control" type="email"
                           placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password">Password</label>
                    <input asp-for="Password" class="form-control" type="password"
                           placeholder="••••••••" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>

                <button type="submit" class="btn-login">Sign In</button>
            </form>
        </div>
    </div>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
</body>
</html>
