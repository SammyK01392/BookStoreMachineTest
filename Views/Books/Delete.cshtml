@model BookStoreMachineTest.Models.Book
@{
    ViewData["Title"] = "Delete Book";
}

<div class="detail-page">
    <div class="detail-card">
        <h2>Delete Book</h2>

        <div class="delete-warning">
            ⚠️ Are you sure you want to permanently delete this book?
        </div>

        <dl>
            <div class="detail-row">
                <dt>Title</dt>
                <dd>@Model.Title</dd>
            </div>
            <div class="detail-row">
                <dt>Author</dt>
                <dd>@Model.Author</dd>
            </div>
            <div class="detail-row">
                <dt>Category</dt>
                <dd><span class="book-category">@Model.Category</span></dd>
            </div>
            <div class="detail-row">
                <dt>Price</dt>
                <dd><strong class="book-price">$@Model.Price.ToString("F2")</strong></dd>
            </div>
            <div class="detail-row">
                <dt>Description</dt>
                <dd>@Model.Description</dd>
            </div>
        </dl>

        <form asp-action="Delete" style="margin-top:1.5rem;">
            <input type="hidden" asp-for="Id" />
            <div class="form-actions">
                <button type="submit" class="btn-primary" style="background:#ef4444;">
                    Yes, Delete
                </button>
                <a asp-action="Index" class="btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
